rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: models
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - description: string (optional, 0-500 chars)
    //   - systemInstruction: string (required, 1-5000 chars)
    //   - examples: list (optional, max 50 items)
    //   - creatorId: string (required, immutable)
    //   - creatorName: string (required)
    //   - createdAt: number (required, immutable)
    //   - isPublic: bool (required)
    //   - webAccessEnabled: bool (required)
    //   - deepThinkEnabled: bool (required)
    //   - personalLaptopEnabled: bool (required)
    //   - rating: number (0-5)
    //   - reviewCount: number (>=0)
    //   - downloads: number (>=0)
    //
    // Collection: models/{modelId}/reviews
    // Fields:
    //   - modelId: string (required, immutable)
    //   - userId: string (required, immutable)
    //   - userName: string (required)
    //   - rating: number (1-5)
    //   - comment: string (0-1000 chars)
    //   - createdAt: number (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidModel(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.systemInstruction is string && data.systemInstruction.size() > 0 &&
             data.creatorId is string &&
             data.creatorName is string &&
             data.createdAt is number &&
             data.isPublic is bool &&
             // Make newer fields optional for legacy data compatibility
             (!('webAccessEnabled' in data) || data.webAccessEnabled is bool) &&
             (!('deepThinkEnabled' in data) || data.deepThinkEnabled is bool) &&
             (!('personalLaptopEnabled' in data) || data.personalLaptopEnabled is bool);
    }

    function isValidReview(data) {
      return data.modelId is string &&
             data.userId is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000 &&
             data.createdAt is number;
    }

    function isValidChat(data) {
      return data.userId is string &&
             data.messages is list &&
             data.createdAt is number &&
             data.updatedAt is number &&
             (!('title' in data) || data.title is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /chats/{chatId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
                      isValidChat(request.resource.data) && 
                      request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && 
                      isValidChat(request.resource.data) && 
                      resource.data.userId == request.auth.uid &&
                      request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /models/{modelId} {
      allow read: if true; // Public models are viewable, private ones filtered by query or handled by logic
      allow create: if isAuthenticated() && 
                      isValidModel(request.resource.data) && 
                      request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuthenticated() && 
                      isValidModel(request.resource.data) && 
                      (
                        // Owner can update everything except immutable fields
                        (request.auth.uid == resource.data.creatorId && 
                         request.resource.data.creatorId == resource.data.creatorId &&
                         request.resource.data.createdAt == resource.data.createdAt) ||
                        // Others can only update rating/downloads (simulated)
                        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewCount', 'downloads']))
                      );
      allow delete: if isOwner(resource.data.creatorId);

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated() && 
                        isValidReview(request.resource.data) && 
                        request.resource.data.userId == request.auth.uid;
        allow update: if isOwner(resource.data.userId) && 
                        isValidReview(request.resource.data) &&
                        request.resource.data.userId == resource.data.userId &&
                        request.resource.data.modelId == resource.data.modelId &&
                        request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(resource.data.userId);
      }
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
